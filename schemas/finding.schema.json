{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finding",
  "type": "object",
  "required": [
    "id",
    "pillar",
    "severity",
    "title",
    "recommendation",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "pillar": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "title": {
      "type": "string"
    },
    "impact": {
      "type": "string"
    },
    "effort": {
      "type": "string"
    },
    "recommendation": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    }
  }
}