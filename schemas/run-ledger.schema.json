{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunLedgerEntry",
  "type": "object",
  "required": [
    "run_id",
    "tenant_id",
    "repo_id",
    "snapshot_id",
    "started_at",
    "status"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "repo_id": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "ended_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "succeeded",
        "failed"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    }
  }
}